const WORDS = new Set(RAW.split(/\s+/).filter(w=>w.length===4));

/* ================= ÉTAT (4 PARTIES INDÉPENDANTES) ================= */
const STATES = {
  VERT:  { grid:Array(16).fill(""), touched:Array(16).fill(false), started:false },
  BLEU:  { grid:Array(16).fill(""), touched:Array(16).fill(false), started:false },
  ROUGE: { grid:Array(16).fill(""), touched:Array(16).fill(false), started:false },
  NOIR:  { grid:Array(16).fill(""), touched:Array(16).fill(false), started:false }
};

let selected=null;
let LVL="VERT";

function S(){ return STATES[LVL]; }          // state courant
function G(){ return STATES[LVL].grid; }     // grille courante
function T(){ return STATES[LVL].touched; }  // touched courant

/* ================= GRILLE ================= */
function initGrid(){
  gridDiv.innerHTML="";
  for(let i=0;i<16;i++){
    const c=document.createElement("div");
    c.className="cell";
    c.onclick=()=>cellClick(i);
    gridDiv.appendChild(c);
  }
}
function refresh(){
  document.querySelectorAll(".cell").forEach((c,i)=>{
    c.textContent=G()[i];
    c.className="cell "+LVL.toLowerCase();
    if(T()[i])c.classList.add("blanc");
    if(selected===i)c.classList.add("selected");
  });
}
function cellClick(i){
  if(G()[i]){G()[i]="";T()[i]=true;selected=null}
  else selected=i;
  refresh();
}

/* ================= CLAVIERS ================= */
function key(L){
  const k=document.createElement("div");
  k.className="key "+LVL.toLowerCase();
  k.textContent=L;
  k.onclick=()=>{
    if(selected!==null){
      G()[selected]=L;
      T()[selected]=true;
      selected=null;
      refresh();
    }
  };
  return k;
}
function initKeyboards(){
  voyelles.innerHTML="";
  const vr=document.createElement("div");
  vr.className="keyboard-row";
  "AEIOUY".split("").forEach(L=>vr.appendChild(key(L)));
  voyelles.appendChild(vr);

  consonnes.innerHTML="";
  ["BCDFG","HJKLM","NPQRS","TVWXZ"].forEach(r=>{
    const d=document.createElement("div");
    d.className="keyboard-row";
    r.split("").forEach(L=>d.appendChild(key(L)));
    consonnes.appendChild(d);
  });
}

/* ================= CLAVIER PC ================= */
document.addEventListener("keydown",e=>{
  if(selected===null)return;
  const k=e.key.toUpperCase();
  if(k>="A"&&k<="Z"){
    G()[selected]=k;T()[selected]=true;selected=null;refresh();e.preventDefault();
  }
  if(e.key==="Backspace"||e.key==="Delete"){
    G()[selected]="";T()[selected]=true;selected=null;refresh();e.preventDefault();
  }
});

/* ================= JEU ================= */
function randomVowelFor(state){
  const v="AEIOU";
  const p=Math.floor(Math.random()*16);
  state.grid[p]=v[Math.floor(Math.random()*v.length)];
  state.touched[p]=true;
}
function randomVowel(){
  randomVowelFor(S());
}

function setKeyboard(m){
  document.body.classList.remove("clavier-noir","clavier-blanc");
  document.body.classList.add(m==="noir"?"clavier-noir":"clavier-blanc");
}
function setKeyboardAuto(){document.body.classList.remove("clavier-noir","clavier-blanc")}

/* ✅ CORRECTION PRINCIPALE :
   setLvl() = NAVIGATION UNIQUEMENT
   (plus de grid.fill / touched.fill / randomVowel ici)
*/
function setLvl(l){
  LVL=l;
  selected=null;

  gridWrapper.className=l.toLowerCase();
  setKeyboardAuto();
  initKeyboards();

  // Si c'est la première fois qu'on va sur cette couleur : on initialise UNE fois
  if(!S().started){
    S().grid.fill("");
    S().touched.fill(false);
    randomVowelFor(S());
    S().started=true;
  }

  refresh();
}

/* ✅ NOUVELLE PARTIE = RESET LOCAL (couleur courante uniquement) */
function nouvelle(){
  S().grid.fill("");
  S().touched.fill(false);
  selected=null;
  randomVowelFor(S());
  S().started=true;
  refresh();
}

/* ================= VALIDATION ================= */
function valider(){
  if(G().some(x=>!x)){
    showModal("<h2>✗ Grille non valide</h2>Grille incomplète.");
    return;
  }
  const rows=[
    G().slice(0,4).join(""),
    G().slice(4,8).join(""),
    G().slice(8,12).join(""),
    G().slice(12,16).join("")
  ];
  const cols=[
    G()[0]+G()[4]+G()[8]+G()[12],
    G()[1]+G()[5]+G()[9]+G()[13],
    G()[2]+G()[6]+G()[10]+G()[14],
    G()[3]+G()[7]+G()[11]+G()[15]
  ];
  const ok=[...rows,...cols].every(w=>WORDS.has(w));
  showModal(ok
    ?"<h2>🎉 Bravo !</h2>Grille valide !"
    :"<h2>✗ Grille non valide</h2>Vous pouvez continuer.");
}

/* ================= POPUP ================= */
function showModal(html){
  modalBox.className=LVL.toLowerCase();
  modalBox.innerHTML=html;
  modalBg.style.display="block";
  modalBg.onclick=()=>modalBg.style.display="none";
}
function showRules(){
  showModal(`
    <h2>COMMENT JOUER ?</h2>
    Choisir une couleur de grille.<br><br>
    Cliquez sur une case de la grille puis tapez une lettre au clavier<br><br>
    Pour effacer : cliquez sur la lettre choisie<br><br>
    🎉 Bonne partie !
  `);
}

/* ================= INIT ================= */
const gridDiv=document.getElementById("grid");
const gridWrapper=document.getElementById("grid-wrapper");
const voyelles=document.getElementById("voyelles");
const consonnes=document.getElementById("consonnes");
const modalBg=document.getElementById("modalBg");
const modalBox=document.getElementById("modalBox");

initGrid();
setLvl("VERT"); // initialise VERT une seule fois puis navigation conserve tout
</script>

</body>
</html>
